{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "BUILD_PLUGIN": true,
        "ENABLE_FRONTEND_API": false,
        "ENABLE_QT": false,
        "ENABLE_TESTS": true
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "Build obs-auto-framing for Windows x64",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "windows-core-tests",
      "displayName": "Windows Core Tests",
      "description": "Build core tests without requiring OBS development files",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_tests",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "cacheVariables": {
        "BUILD_PLUGIN": false,
        "ENABLE_TESTS": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "displayName": "Windows x64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-core-tests",
      "configurePreset": "windows-core-tests",
      "displayName": "Windows Core Tests",
      "configuration": "RelWithDebInfo"
    }
  ]
}
